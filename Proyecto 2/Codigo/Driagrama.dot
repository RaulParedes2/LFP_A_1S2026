digraph AFD_TaskScript {
    rankdir=TB;
    node [shape=circle, style=filled, fillcolor=lightblue, fontname="Arial", fontsize=11];
    edge [fontname="Arial", fontsize=10];
    
    // Estados
    q0 [label="q0", fillcolor="#90EE90"];
    q1 [label="q1"];
    q2 [label="q2"];
    q3 [label="q3"];
    q4 [label="q4"];
    q5 [label="q5"];
    q6 [label="q6"];
    q7 [label="q7"];
    q8 [label="q8"];
    q9 [label="q9"];
    q_error [label="q_error", fillcolor="#FF4444", fontcolor="white"];
    
    // Estado inicial con flecha
    start [shape=point, width=0.2];
    start -> q0;
    
    // Transiciones desde q0
    q0 -> q0 [label="W (espacio,\\t,\\n,\\r)"];
    q0 -> q1 [label="L [a-zA-Záéíóúñ_]"];
    q0 -> q2 [label='"'"];
    q0 -> q3 [label="N [0-9]"];
    q0 -> q9 [label="S [{}[\\]:,;]"];
    
    // Transiciones desde q1 (palabra)
    q1 -> q1 [label="L | N | _"];
    q1 -> q0 [label="otro", style=dashed];
    
    // Transiciones desde q2 (cadena)
    q2 -> q2 [label="caracteres (excepto \")"];
    q2 -> q0 [label='""', style=bold ];
    q2 -> q_error [label="\\n | EOF"];
    
    // Transiciones desde q3 (número)
    q3 -> q3 [label="N"];
    q3 -> q4 [label="'-'"];
    q3 -> q0 [label="otro", style=dashed];
    
    // Transiciones para fechas
    q4 -> q4 [label="N"];
    q4 -> q5 [label="'-'"];
    q4 -> q0 [label="otro", style=dashed];
    
    q5 -> q6 [label="N"];
    q5 -> q0 [label="otro", style=dashed];
    
    q6 -> q6 [label="N"];
    q6 -> q7 [label="'-'"];
    q6 -> q0 [label="otro", style=dashed];
    
    q7 -> q8 [label="N"];
    q7 -> q0 [label="otro", style=dashed];
    
    q8 -> q8 [label="N"];
    q8 -> q0 [label="otro", style=dashed];
    
    // Transición desde q9 (símbolo)
    q9 -> q0 [label="cualquier"];
    
    // Auto-transición error
    q_error -> q_error [label="cualquier"];
    
    // Estados finales
    q0 [peripheries=2];
    q1 [peripheries=2];
    q2 [peripheries=2];
    q3 [peripheries=2];
    q4 [peripheries=2];
    q5 [peripheries=2];
    q6 [peripheries=2];
    q7 [peripheries=2];
    q8 [peripheries=2];
    q9 [peripheries=2];
    
    // Leyenda
    subgraph cluster_legend {
        label="Leyenda";
        style=dashed;
        color=gray;
        
        l1 [shape=plaintext, label="W = espacio, tab, \\n, \\r", fontsize=9];
        l2 [shape=plaintext, label="L = a-z A-Z áéíóúñ _", fontsize=9];
        l3 [shape=plaintext, label="N = 0-9", fontsize=9];
        l4 [shape=plaintext, label='S = { } [ ] : , ;', fontsize=9];
        
        l1 -> l2 -> l3 -> l4 [style=invis];
    }
}